<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield Outer Glow -->
    <path
        android:pathData="M54,20 L80,29 C80,56 68,77 54,88 C40,77 28,56 28,29 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="20"
                android:endX="54"
                android:endY="88"
                android:type="linear">
                <item android:offset="0.0" android:color="#2563EB" />
                <item android:offset="1.0" android:color="#06B6D4" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Shield Shield Layer for Depth -->
    <path
        android:pathData="M54,26 L74,33 C74,54 64,71 54,80 C44,71 34,54 34,33 Z"
        android:fillColor="#09132C" />

    <!-- Security Checkmark glowing inside the shield -->
    <path
        android:pathData="M44,53 L51,60 L64,47"
        android:strokeWidth="5.5"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />

    <!-- Technical Cyber/AI dots on shield path corners to give AI futuristic look -->
    <group>
        <!-- Top Left -->
        <path
            android:pathData="M24,25 A2,2 0 1,1 24,21 A2,2 0 1,1 24,25"
            android:fillColor="#00FFCC" />
        <!-- Top Right -->
        <path
            android:pathData="M84,25 A2,2 0 1,1 84,21 A2,2 0 1,1 84,25"
            android:fillColor="#00FFCC" />
        <!-- Bottom Peak -->
        <path
            android:pathData="M54,94 A2,2 0 1,1 54,90 A2,2 0 1,1 54,94"
            android:fillColor="#00FFCC" />
    </group>
</vector>
